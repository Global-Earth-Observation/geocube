ARG REPOSITORY
FROM ${REPOSITORY}/geocube-base:latest AS builder

WORKDIR /build
COPY go.* /build/
COPY vendor vendor
COPY internal internal
COPY interface interface
COPY cmd cmd
COPY cmd/server server

RUN cd server && go build -ldflags="-s -w" .

